  "filters": {
    "refetch": true,
    "defaults": { "since": "week", "lang": "all" },
    "controls": [
      { "type": "segment", "key": "since", "label": "fSince", "icon": "lucide:calendar", "refetch": true, "chip": true,
        "options": [["day", "sinceDay"], ["week", "sinceWeek"], ["month", "sinceMonth"]] },
      { "type": "segment", "key": "lang", "label": "fLang", "icon": "lucide:code", "refetch": true, "chip": true,
        "options": [["all", "langAll"], ["JavaScript", "JS"], ["Python", "Python"], ["Rust", "Rust"], ["Go", "Go"]] }
    ]
  },
  "profile": { "icon": "lucide:github", "theme": true, "lang": true, "install": true, "source": { "label": "profSource", "url": "https://github.com/", "icon": "lucide:database" } },
